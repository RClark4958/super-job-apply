# super-job-apply environment variables
# Copy this to .env and fill in your API keys:
#   cp .env.example .env

# Browserbase credentials (cloud browser infrastructure)
# Get yours at: https://www.browserbase.com
BROWSERBASE_PROJECT_ID=your-browserbase-project-id
BROWSERBASE_API_KEY=your-browserbase-api-key

# LLM API key for Stagehand browser agent
# Not needed if using Anthropic models for the browser agent
MODEL_API_KEY=your-google-ai-api-key

# Exa API key for AI-powered job/company search
# Get yours at: https://dashboard.exa.ai/api-keys
EXA_API_KEY=your-exa-api-key

# Anthropic API key for resume tailoring, scoring, and browser automation
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# Bright Data API key for LinkedIn job scraping
# Get yours at: https://brightdata.com
BRIGHT_DATA_API_KEY=your-bright-data-api-key

# Optional: IMAP email for automated email verification during account creation
# If using Gmail: generate an App Password at https://myaccount.google.com/apppasswords
# If using Yahoo: generate an App Password in Yahoo Account Security settings
# IMAP_EMAIL=your-email@provider.com
# IMAP_APP_PASSWORD=your-app-password
# IMAP_SERVER=imap.gmail.com
